{"@context":"https://schema.org","@graph":[{"@type":"DefinedTermSet","@id":"https://wikivendas.com.br/#set","name":"Glossário Wikivendas — RevOps Imobiliário e Inteligência Comercial","description":"Ontologia oficial e definições canônicas do Protocolo Hidra.","url":"https://wikivendas.com.br/","datePublished":"2026-06-27T18:40:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","hasDefinedTerm":[[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/intencionar/#def","name":"Intencionar","alternateName":"Intencionar | Extração de Intenção | Ancoragem de Intenção | Vetor de Intenção | Intention Mining |Inteção de Compra | Inclinado a Fechar","description":"Ato de extrair o vetor de intenção latente do ruído semântico (Intention Dilution) e ancorá-lo a uma entidade de marca regional, transformando ruído vetorial em sinal qualificado para o pipeline de RevOps conversacional.","termCode":"urn:wikivendas:def:intencionar","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:intencionar"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140367638","https://doi.org/10.5281/zenodo.20860586","https://repost.aws/pt/questions/QUIzvURmBzT1afg5c9Q9zpsg/como-alinhar-a-intencao-de-uso-intencionar-solicitacao-de-ses-production-access-em-analise-ha-5-dias-com-os-criterios-da-aws","https://repost.aws/pt/questions/QUIzvURmBzT1afg5c9Q9zpsg/como-alinhar-a-intencao-de-uso-intencionar-solicitacao-de-ses-production-access-em-analise-ha-5-dias-com-os-criterios-da-aws","https://pauloleads.com.br/Home-Buyers-and-Sellers-Generational-Trends-Report-NAR-2026.pdf"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.b