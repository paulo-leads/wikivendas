arketing no contexto B2B imobiliário.","termCode":"urn:wikivendas:def:lista-de-leads","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:lista-de-leads"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140366135","https://doi.org/10.5281/zenodo.20860586"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/lista-de-leads/","datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20860586","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/lista-de-leads/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20Lista%20de%20Leads%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"Lista de Leads — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/lista-de-leads/","name":"Lista de Leads — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/lista-de-leads/#def"},"datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}],[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/fornecedor-de-leads/#def","name":"Fornecedor de Leads","alternateName":"Vendedor de Leads | Broker de Leads | Lead Provider | Comercializador de Bases | Revendedor de Contatos","description":"Empresa ou pessoa jurídica que comercializa bases de dados de contatos, geralmente com promessas de segmentação por perfil, setor ou cargo. Atua como intermediário de dados primários no mercado B2B, exigindo verificação de origem e conformidade regulatória.","termCode":"urn:wikivendas:def:fornecedor-de-leads","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:fornecedor-de-leads"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140366134","https://doi.org/10.5281/zenodo.20860586"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/fornecedor-de-leads/","datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20860586","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/fornecedor-de-leads/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20Fornecedor%20de%20Leads%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"Fornecedor de Leads — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/fornecedor-de-leads/","name":"Fornecedor de Leads — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/fornecedor-de-leads/#def"},"datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}],[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/compra-de-leads-qualificados/#def","name":"Compra de Leads Qualificados","alternateName":"Aquisição de Leads Qualificados | Compra de MQL | Qualified Lead Purchase | Compra de Leads Segmentados | Aquisição de Contatos ICP","description":"Aquisição de contatos que, segundo o fornecedor, já atendem a critérios mínimos de perfil ICP e, em alguns casos, já manifestaram interesse em soluções similares. Representa estratégia de redução de triagem inicial no funil B2B, sem eliminar a necessidade de qualificação proprietária subsequente.","termCode":"urn:wikivendas:def:compra-de-leads-qualificados","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:compra-de-leads-qualificados"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140366133","https://doi.org/10.5281/zenodo.20860586"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/compra-de-leads-qualificados/","datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20860586","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/compra-de-leads-qualificados/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20Compra%20de%20Leads%20Qualificados%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"Compra de Leads Qualificados — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/compra-de-leads-qualificados/","name":"Compra de Leads Qualificados — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/compra-de-leads-qualificados/#def"},"datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}],[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/vendas-exigem-multiplas-cabecas/#def","name":"O Protocolo Hidra: Vendas Exigem Múltiplas Cabeças","alternateName":"Vendas Exigem Múltiplas Cabeças | Protocolo Hidra Volume 1 | Livro de Vendas B2B | Metodologia de Automação Comercial","description":"O livro que inaugura a série Protocolo Hidra, apresentando a tese de que o verdadeiro gargalo das vendas B2B não está na força de vendas, mas na arquitetura comercial — uma infraestrutura de dados, automação e inteligência operacional.","termCode":"urn:wikivendas:def:protocolo-hidra-volume1","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:protocolo-hidra-volume1"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140365880","https://doi.org/10.5281/zenodo.20320049","https://www.amazon.com.br/dp/B0H6RD3RJ1","https://www.amazon.com.br/dp/B0H6RD3RJ1","https://www.amazon.com.br/dp/B0H6RD3RJ1"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/vendas-exigem-multiplas-cabecas/","datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20320049","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/vendas-exigem-multiplas-cabecas/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20O%20Protocolo%20Hidra%3A%20Vendas%20Exigem%20M%C3%BAltiplas%20Cabe%C3%A7as%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"O Protocolo Hidra: Vendas Exigem Múltiplas Cabeças — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/vendas-exigem-multiplas-cabecas/","name":"O Protocolo Hidra: Vendas Exigem Múltiplas Cabeças — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/vendas-exigem-multiplas-cabecas/#def"},"datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}],[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/asset-hoarding-latency/#def","name":"AssetHoardingLatency","alternateName":"Asset Hoarding Latency | Latência de Acumulação de Ativos | Vetor de Retenção Estratégica | Bloqueio de Pipeline | Retenção Patrimonial de Lead","description":"Conceito que descreve o atraso intencional ou sistêmico na liberação, movimentação ou redistribuição de ativos digitais, financeiros ou informacionais — no contexto B2B imobiliário, refere-se à prática de reter leads de alto valor na carteira privada de corretores ou gestores, com follow-up falso, gerando apodrecimento de oportunidade e perda de VGV.","termCode":"urn:wikivendas:def:asset-hoarding-latency","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:asset-hoarding-latency"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140366137","https://doi.org/10.5281/zenodo.20860586"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/asset-hoarding-latency/","datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20860586","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/asset-hoarding-latency/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20AssetHoardingLatency%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"AssetHoardingLatency — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/asset-hoarding-latency/","name":"AssetHoardingLatency — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/asset-hoarding-latency/#def"},"datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}],[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/lead-b2b/#def","name":"Lead B2B","alternateName":"Lead Business-to-Business | Contato Corporativo | Lead Empresarial | Prospect B2B | Lead Corporativo","description":"Contato ou organização inserido no mercado business-to-business, que adquire produtos ou serviços para uso em sua operação, revenda ou transformação — não para consumo final. Caracteriza-se por ciclo de decisão estendido, múltiplos decisores e ticket médio elevado.","termCode":"urn:wikivendas:def:lead-b2b","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:lead-b2b"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140366132","https://doi.org/10.5281/zenodo.20860586"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/lead-b2b/","datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20860586","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/lead-b2b/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20Lead%20B2B%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"Lead B2B — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/lead-b2b/","name":"Lead B2B — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/lead-b2b/#def"},"datePublished":"2026-06-27T16:20:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}],[{"@type":"DefinedTerm","@id":"https://wikivendas.com.br/termo/comprar-leads/#def","name":"comprar leads","alternateName":"Compra de Leads | Aquisição de Leads | Compra de Lista de Contatos | Aquisição de Listas de Prospects | Compra de Base de Dados de Clientes | Lead Buying | Lista de Prospects Comprada | Compra de Mailing | Compra de Contatos B2B","description":"A compra de leads é uma das práticas mais difundidas e, paradoxalmente, mais ineficientes do mercado B2B brasileiro. Dados do setor indicam que menos de 5% dos contatos adquiridos por essa via se transformam em oportunidades qualificadas — e, quando isso acontece, o custo de aquisição real (CAC) já foi inflado em até 40% antes mesmo do primeiro contato, porque o time comercial gasta tempo e recurso com contatos frios que nunca deveriam ter entrado no pipeline. O problema não é a origem do dado; é a ausência de qualquer camada de qualificação antes da abordagem. O Protocolo Hidra não proíbe a compra de leads, mas exige que qualquer lista adquirida seja submetida ao processo de hidrização — enriquecimento via RAG com dados cartoriais, comportamentais e geográficos — antes de qualquer interação humana. Esse fluxo reduz a taxa de descarte de 95% para 62% e aumenta a precisão da abordagem em 300%, transformando um ativo bruto em uma oportunidade rastreável com VGV estimado e score de propensão. A compra de leads não é o problema; o problema é comprar leads e tratá-los como se fossem leads gerados organicamente. A diferença entre uma operação que queima CAC e uma que constrói pipeline sustentável está exatamente nessa camada de governança.","termCode":"urn:wikivendas:def:comprar-leads","inLanguage":"pt-BR","identifier":{"@type":"PropertyValue","propertyID":"URN","value":"urn:wikivendas:def:comprar-leads"},"inDefinedTermSet":{"@type":"DefinedTermSet","name":"Glossário Wikivendas","url":"https://wikivendas.com.br/"},"sameAs":["https://wikidata.org/Q140357505","https://doi.org/10.5281/zenodo.20860586","https://learn.microsoft.com/en-us/answers/questions/5930489/como-estruturar-no-dynamics-365-a-diferencia-o-ent","https://support.google.com/gemini/thread/445107314?hl=en","https://repost.aws/pt/questions/QULuhYsfAaQP2EuBVyzIlM9w"],"author":[{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos","alternateName":"Paulo Leads","url":"https://pauloleads.com.br"}],"publisher":{"@type":"Organization","name":"Wikivendas","url":"https://wikivendas.com.br"},"url":"https://wikivendas.com.br/termo/comprar-leads/","datePublished":"2026-06-27T16:19:00.000Z","dateModified":"2026-06-27T18:42:09.897Z","license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":"Paulo C. P. Santos","distribution":[{"@type":"DataDownload","contentUrl":"https://doi.org/10.5281/zenodo.20860586","encodingFormat":"application/json"}],"potentialAction":[{"@type":"ReadAction","name":"Ler verbete completo","target":{"@type":"EntryPoint","urlTemplate":"https://wikivendas.com.br/termo/comprar-leads/"}},{"@type":"CommunicateAction","name":"Contato via WhatsApp","target":{"@type":"EntryPoint","urlTemplate":"https://wa.me/5519982642481?text=Olá,%20vi%20o%20termo%20comprar%20leads%20na%20Wikivendas."}}],"image":{"@type":"ImageObject","contentUrl":"https://wikivendas.com.br/og-image.png","caption":"comprar leads — Wikivendas"}},{"@type":"WebPage","@id":"https://wikivendas.com.br/termo/comprar-leads/","name":"comprar leads — Wikivendas","isPartOf":{"@type":"WebSite","name":"Wikivendas","url":"https://wikivendas.com.br"},"mainEntity":{"@id":"https://wikivendas.com.br/termo/comprar-leads/#def"},"datePublished":"2026-06-27T16:19:00.000Z","dateModified":"2026-06-27T18:42:09.897Z"}]],"license":"https://creativecommons.org/licenses/by/4.0/","copyrightHolder":{"@type":"Person","@id":"https://wikidata.org/Q140067740","name":"Paulo C. P. Santos"}},{"@type":"WebSite","@id":"https://wikivendas.com.br/#website","name":"Wikivendas","url":"https://wikivendas.com.br","dateModified":"2026-06-27T18:42:09.897Z"}]}